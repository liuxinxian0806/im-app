{
  "name": "im-desktop-app",
  "version": "1.0.0",
  "description": "A high-performance, cross-platform Desktop IM application.",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && shx mkdir -p dist/main && shx cp electron/main.ts dist/main/index.js && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "files": [
    "dist/**",
    "src/**"
  ],
  "dependencies": {
    "lucide-react": "^0.330.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "postcss": "^8.4.35",
    "shx": "^0.4.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "6.4.3"
  },
  "build": {
    "appId": "com.example.imapp",
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDir": true,
      "createDesktopShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installLocation": null
    },
    "files": [
      "dist/**",
      "src/**"
    ]
  },
  "author": "liuxx"
}
